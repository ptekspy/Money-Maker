{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [".env", ".env.local"],
  "globalEnv": [
    "DATABASE_URL",
    "ADMIN_PASSWORD",
    "OLLAMA_BASE_URL",
    "OLLAMA_MODEL",
    "GMAIL_USER",
    "GMAIL_APP_PASSWORD",
    "CONTRACTGUARD_GITHUB_APP_ID",
    "CONTRACTGUARD_GITHUB_CLIENT_ID",
    "CONTRACTGUARD_GITHUB_CLIENT_SECRET",
    "CONTRACTGUARD_GITHUB_PRIVATE_KEY",
    "CONTRACTGUARD_GITHUB_WEBHOOK_SECRET",
    "CONTRACTGUARD_GITHUB_APP_SLUG",
    "CONTRACTGUARD_SESSION_SECRET",
    "CONTRACTGUARD_APP_URL",
    "CONTRACTGUARD_STRIPE_SECRET_KEY",
    "CONTRACTGUARD_STRIPE_WEBHOOK_SECRET",
    "CONTRACTGUARD_STRIPE_PRICE_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "out/**"]
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
